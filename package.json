{
  "name": "eastern-state-kpi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=24",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "bash ./scripts/dev.sh",
    "dev:stable": "WATCHPACK_POLLING=true WATCHPACK_POLLING_INTERVAL=1000 bash ./scripts/dev.sh",
    "build": "next build --webpack",
    "start": "next start -p 3000",
    "start:deploy": "bash ./scripts/start-production.sh",
    "db:migrate": "tsx scripts/migrate.ts",
    "typecheck": "AUTH_DISABLED= next typegen && tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "db:seed": "tsx scripts/seed.ts",
    "setup:admin": "tsx scripts/setup-admin.ts",
    "hygiene:guard": "bash ./scripts/repository-hygiene-guard.sh",
    "architecture:guard": "bash ./scripts/architecture-boundary-guard.sh",
    "docstrings:guard": "node scripts/docstring-coverage.mjs",
    "docstrings:fix": "node scripts/docstring-coverage.mjs --fix",
    "design-system:guard": "bash ./scripts/design-tokens-guard.sh && bash ./scripts/design-system-guard.sh && bash ./scripts/auth-bypass-guard.sh && bash ./scripts/architecture-boundary-guard.sh",
    "quality:guards": "npm run design-system:guard && npm run hygiene:guard && npm run docstrings:guard && npm run production-dependencies:guard && bash ./scripts/d8ad-can-008-ci-gate.sh",
    "design-system:test": "npm run quality:guards && npm run typecheck && AUTH_DISABLED= npm run build",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default",
    "test:e2e": "playwright test",
    "security:dependencies": "node scripts/run-osv-scanner.mjs",
    "security:secrets": "node scripts/run-gitleaks.mjs",
    "security:semgrep": "node scripts/run-semgrep.mjs",
    "security:scan": "npm run security:dependencies && npm run security:secrets && npm run security:semgrep",
    "production-dependencies:guard": "node scripts/production-dependency-guard.mjs",
    "check": "npm run typecheck && npm run lint && npm run test:ci",
    "check:all": "npm run check && npm run build && npm run test:e2e",
    "perf:profile": "node scripts/performance-profile.mjs",
    "test:coverage": "vitest run --coverage",
    "prelint": "npm run quality:guards"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "iron-session": "^8.0.4",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.453.0",
    "next": "16.2.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.9.2",
    "sharp": "0.35.3",
    "tsx": "^4.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.11",
    "eslint-import-resolver-typescript": "^4.4.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.9",
    "yaml": "2.9.0"
  },
  "allowScripts": {
    "core-js@3.49.0": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.35.3": true,
    "unrs-resolver@1.12.2": true,
    "fsevents@2.3.2": true
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "$sharp"
  }
}
