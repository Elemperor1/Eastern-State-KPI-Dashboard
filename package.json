{
  "name": "eastern-state-kpi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "start:deploy": "bash ./scripts/start-production.sh",
    "lint": "next lint",
    "db:seed": "tsx scripts/seed.ts",
    "design-system:guard": "bash ./scripts/design-tokens-guard.sh && bash ./scripts/design-system-guard.sh",
    "design-system:test": "bash ./scripts/design-tokens-guard.sh && bash ./scripts/design-system-guard.sh && npx tsc --noEmit && AUTH_DISABLED= npx next build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prelint": "npm run design-system:guard"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "iron-session": "^8.0.4",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.453.0",
    "next": "15.5.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "core-js@3.49.0": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
